{
  "name": "@programmer1zero1/expo-responsive-window",
  "version": "1.0.2",
  "description": "Window-aware breakpoints, scaled design pixels, and gutters for Expo / React Native. Live on rotation & resize. Includes README + AGENTS.md.",
  "license": "MIT",
  "author": "Muhammad Ramzan <programmer1zero1@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/programmer1zero1/expo-responsive-window.git"
  },
  "homepage": "https://github.com/programmer1zero1/expo-responsive-window#readme",
  "bugs": {
    "url": "https://github.com/programmer1zero1/expo-responsive-window/issues"
  },
  "keywords": [
    "expo",
    "react-native",
    "responsive",
    "dimensions",
    "breakpoints",
    "tablet",
    "layout",
    "responsive-window",
    "expo-web"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "LICENSE",
    "README.md",
    "AGENTS.md"
  ],
  "scripts": {
    "build": "tsup src/index.tsx --clean --dts --format esm --format cjs --external react --external react-native --sourcemap",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.71.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "tsup": "^8.5.1",
    "typescript": "~5.9.2"
  }
}
